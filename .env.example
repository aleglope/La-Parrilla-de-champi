# ============================================================
# La Parrilla de Champi — Variables de entorno
# Copia este archivo a .env.local y rellena los valores reales:
#   cp .env.example .env.local
# Los valores reales NUNCA se commitean (.env.local está gitignoreado).
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
# URL y claves del proyecto: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Secreto: bypassa RLS — nunca exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Resend (email transaccional) ───────────────────────────
# API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Admin (panel de gestión) ───────────────────────────────
ADMIN_EMAIL=admin@example.com
# Sin fallback: la app falla si falta
ADMIN_PASSWORD=change-me
# Firma HMAC de la sesión admin — generar con: openssl rand -base64 32
ADMIN_JWT_SECRET=generate-with-openssl-rand-base64-32
# Secreto del endpoint /api/revalidate — generar con: openssl rand -base64 32
REVALIDATE_SECRET=generate-with-openssl-rand-base64-32

# ─── Sentry (observabilidad — opcional) ─────────────────────
# Si se omiten, Sentry queda en no-op y el build pasa sin problemas.
# DSN cliente (público)
NEXT_PUBLIC_SENTRY_DSN=
# DSN servidor/edge
SENTRY_DSN=
# Opcional: solo CI/Vercel — habilita la subida de source maps en build
SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
